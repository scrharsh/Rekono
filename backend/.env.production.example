NODE_ENV=production
PORT=3000

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rekono?retryWrites=true&w=majority

JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRATION=7d

ALLOWED_ORIGINS=https://your-web.vercel.app

THROTTLE_TTL=60000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

ENABLE_SWAGGER=false

PAYMENT_WEBHOOK_SECRET=replace-with-webhook-shared-secret
RAZORPAY_PAYMENT_WEBHOOK_SECRET=
PHONEPE_WEBHOOK_SECRET=

LOG_LEVEL=info
