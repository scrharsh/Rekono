# Server
NODE_ENV=development
PORT=3000

# MongoDB Atlas (free tier)
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rekono?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRATION=7d

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,https://your-app.vercel.app

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info
